    "relayUnableConnect":  "Não foi possível conectar a NENHUM servidor relay do NetherLink. Tente novamente mais tarde ou verifique sua internet.",
    "howToXboxTitle":  "Xbox / PS4-5 (LAN / conexão proxy)",
    "@howToXboxTitle":  {
                            "description":  "Title for the Xbox / PS4-5 how-to modal"
                        },
    "howToXboxSubtitle":  "Jogue via transmissão LAN ou proxy",
    "@howToXboxSubtitle":  {
